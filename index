  <div id="bug-report-modal" class="modal"><div class="modal-content"><div class="modal-header"><span>🏩 报错急救站</span><button class="nurse-btn nurse-btn-clear" onclick="window.clearBugReport()">🧹 清扫</button></div><div class="modal-body"><textarea id="error-log-viewer" readonly></textarea></div><div class="modal-footer"><button class="nurse-btn nurse-btn-close" onclick="window.closeBugStation()">关闭</button><button class="nurse-btn nurse-btn-copy" onclick="window.copyBugReport()">📋 一键复制报错</button></div></div></div>
</div>

<script>
  (function(){ window.errorLogs = [];
    function captureError(source, msg){ const logLine = `⏰ [${new Date().toLocaleTimeString()}] ${source}\n❌ ${msg}\n----------------------------------\n`; window.errorLogs.push(logLine); const ta = document.getElementById("error-log-viewer"); if(ta){ ta.value = window.errorLogs.join(""); ta.scrollTop = ta.scrollHeight; } }
    const originalError = console.error;
    console.error = function(...args){ const msg = args.map(a=>{ try{ return typeof a === "object" ? JSON.stringify(a) : String(a); }catch(e){ return String(a); } }).join(" "); captureError("Console Error", msg); originalError.apply(console, args); };
    window.addEventListener("error", function(e){ captureError("System Crash", `${e.message}\n📍 位置: ${e.filename}:${e.lineno}`); });
    window.addEventListener("unhandledrejection", function(e){ let reason = e.reason; if(typeof reason === "object") reason = reason.message || JSON.stringify(reason); captureError("Unhandled Promise", reason); });
  })();
  window.openBugStation = function(){ const modal = document.getElementById("bug-report-modal"); const ta = document.getElementById("error-log-viewer"); if(window.errorLogs.length === 0){ ta.value = "✨ 一切正常！没有检测到任何报错 (好耶！)"; ta.style.color = "#52c41a"; ta.style.textAlign = "center"; } else { ta.value = window.errorLogs.join(""); ta.style.color = "#ff4d4f"; ta.style.textAlign = "left"; } modal.classList.add("visible"); };
  window.copyBugReport = function(){ const ta = document.getElementById("error-log-viewer"); if(ta.value.includes("一切正常")){ alert("没有报错，不用复制啦~"); return; } ta.select(); document.execCommand("copy"); alert("💉 报错信息已复制！"); };
  window.clearBugReport = function(){ window.errorLogs = []; window.openBugStation(); };
  window.closeBugStation = function(){ document.getElementById("bug-report-modal").classList.remove("visible"); };
  // 精简版仅保留核心功能，全局变量
  const GEMINI_API_URL = "https://generativelanguage.googleapis.com/v1beta/models";
  function getRandomValue(str){ if(str.includes(",")){ const arr = str.split(",").map(s=>s.trim()); return arr[Math.floor(Math.random()*arr.length)]; } return str; }
  // 模拟部分主逻辑占位，实际运行时由main-app.js接管
</script>
<script src="main-app.js" defer></script>
<script src="forum.js" defer></script>
<script src="avatar-frames.js" defer></script>
</body>
</html>
